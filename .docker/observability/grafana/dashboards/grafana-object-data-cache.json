              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.2
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 0
